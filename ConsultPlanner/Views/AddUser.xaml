<Window x:Class="ConsultPlanner.Views.AddUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConsultPlanner.Views"
        mc:Ignorable="d"
        Title="Добавить пользователя" Height="325" Width="500">
    <Window.Resources>
        <Style x:Key="InputTextView" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="FormButton" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column = "0" Text="Фамилия:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LastName}" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column = "0" Text="Имя:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FirstName}" Margin="5"/>

        <TextBlock Grid.Row="2" Grid.Column = "0" Text="Отчество:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Patronymic}" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column = "0" Text="Дата рождения:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <DatePicker Grid.Row="3" Grid.Column="1" Text="{Binding Birthday}" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column = "0" Text="Телефон:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Phone}" Margin="5"/>

        <TextBlock Grid.Row="5" Grid.Column = "0" Text="Почта:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Email}" Margin="5"/>

        <TextBlock Grid.Row="6" Grid.Column = "0" Text="Пароль:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Password}" Margin="5"/>
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddUserCommand}" Style="{StaticResource ResourceKey=FormButton}"/>
            <Button Content="Отменить" Command="{Binding CancelCommand}" Style="{StaticResource ResourceKey=FormButton}"/>
        </StackPanel>
    </Grid>
</Window>
