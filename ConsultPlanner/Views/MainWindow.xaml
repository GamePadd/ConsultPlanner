<Window x:Class="ConsultPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConsultPlanner.Views"
        mc:Ignorable="d"
        Title="ConsultPlanner" Height="450" Width="800" Background="White">
    <Window.Resources>
        <Style x:Key="Button1" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5 5"/>
            <Setter Property="Padding" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="Blue"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="Black">
            <TextBlock Text="ConsultPlanner"
                       Foreground="White"
                       FontSize="30"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto">
            <StackPanel Orientation="Horizontal">
                <Button Content="Пользователи" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenUsersPage"/>
                <Button Content="Сессии" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenSessionsPage"/>
                <Button Style="{StaticResource ResourceKey=Button1}"
                        Click="AddUserForm">
                    <TextBlock Text="Добавить пользователя" TextWrapping="Wrap" TextAlignment="Center"/>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderThickness="2" BorderBrush="Black" CornerRadius="0" Padding="5" Margin="5 0 5 5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden">
                
            </Frame>
        </Border>
    </Grid>
</Window>
