<Window x:Class="ConsultPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConsultPlanner.Views"
        mc:Ignorable="d"
        FontFamily="Segoe UI Light"
        WindowStyle="None"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="ConsultPlanner" Height="450" Width="800" Background="#242424">
    <Window.Resources>
        <Style x:Key="Button1" TargetType="Button">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0.8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5 0"/>
            <Setter Property="Padding" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#474747"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Margin" Value="20 0 0 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="0" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#474747"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#474747"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness ="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" VerticalAlignment="Center" Margin="20 0">
            <TextBlock Text="ConsultPlanner" FontSize="25" Foreground="White"/>
        </WrapPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15 10">
            <Button x:Name="buttonMinimize" Style="{StaticResource ResourceKey=HeaderButton}" Click="buttonMinimize_Click">
                <Image Source="/Resources/Images/Resize.png"/>
            </Button>
            <Button x:Name="buttonClose" Style="{StaticResource ResourceKey=HeaderButton}" Click="buttonClose_Click">
                <Image Source="/Resources/Images/Exit.png"/>
            </Button>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Margin="15 0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Пользователи" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenUsersPage"/>
                <Button Content="Консультанты" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenConsPage"/>
                <Button Content="Роли" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenRolesPage"/>
                <Button Content="Сессии" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenSessionsPage"/>
                <Button Content="Темы" 
                        Style="{StaticResource ResourceKey=Button1}"
                        Click="OpenTopicsPage"/>
            </StackPanel>
        </ScrollViewer>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"  Grid.Row="2" Margin="15 0 15 15">

        </Frame>
    </Grid>
</Window>
