<Window x:Class="ConsultPlanner.Views.RequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConsultPlanner.Views"
        mc:Ignorable="d"
        Title="Добавить запрос" Height="360" Width="500"
        FontFamily="Segoe UI Light"
        WindowStyle="None"
        Background="#242424"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="InputTextView" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Button1" TargetType="Button">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0.8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5 0"/>
            <Setter Property="Padding" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#474747"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Input1" TargetType="TextBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="DatePicker1" TargetType="DatePicker">
            <Setter Property="Background" Value="#242424"/>
        </Style>
        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Width" Value="15"/>
            <Setter Property="Margin" Value="20 0 0 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="0" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#474747"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#474747"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness ="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="#6C49B8" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="115"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5 0">
                <TextBlock Text="{Binding DialogTitle}" FontSize="20" Foreground="White"/>
            </WrapPanel>
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15 10">
                <Button x:Name="buttonMinimize" Style="{StaticResource ResourceKey=HeaderButton}" Click="buttonMinimize_Click">
                    <Image Source="/Resources/Images/Resize.png"/>
                </Button>
                <Button x:Name="buttonClose" Style="{StaticResource ResourceKey=HeaderButton}" Click="buttonClose_Click">
                    <Image Source="/Resources/Images/Exit.png"/>
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column = "0" Text="Пользователь:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
            <ComboBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" IsTextSearchEnabled="True" Background="#242424" Margin="5" Foreground="Black" Grid.Row="1" Grid.Column="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                    Foreground="Black" Margin="5">
                        <Run Text="{Binding LastName}"/>
                        <Run Text="{Binding FirstName}"/>
                        <Run Text="{Binding Patronymic}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column = "0" Text="Консультант:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
            <ComboBox ItemsSource="{Binding Consultants}" SelectedItem="{Binding SelectedConsultant}" IsTextSearchEnabled="True" Background="#242424" Margin="5" Foreground="Black" Grid.Row="2" Grid.Column="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                        Foreground="Black" Margin="5">
                            <Run Text="{Binding Users.LastName}"/>
                            <Run Text="{Binding Users.FirstName}"/>
                            <Run Text="{Binding Users.Patronymic}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="3" Grid.Column = "0" Text="Описание:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Description}" Height="100" Margin="5" Style="{StaticResource ResourceKey=Input1}"/>

            <TextBlock Grid.Row="4" Grid.Column = "0" Text="Статус:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Status}" Margin="5" Style="{StaticResource ResourceKey=Input1}"/>

            <TextBlock Grid.Row="5" Grid.Column = "0" Text="Дата запроса:" Margin="5" Style="{StaticResource ResourceKey=InputTextView}"/>
            <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding RequestDate}" Margin="5" Style="{StaticResource ResourceKey=DatePicker1}"/>

            <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                <Button Content="Ок" Command="{Binding SaveRequestCommand}" Style="{StaticResource ResourceKey=Button1}"/>
                <Button Content="Отменить" Command="{Binding CancelCommand}" Style="{StaticResource ResourceKey=Button1}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
